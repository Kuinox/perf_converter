<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="Plank local packages" value="Plank\Plank.Native.Zlib\artifacts\packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="Plank local packages">
      <package pattern="Plank.Native.Zlib" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
